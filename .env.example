# Required: OpenAI (for all agents)
OPENAI_API_KEY=sk-...

# Required: Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=...

# Opik observability (optional but recommended)
# Run: opik configure
OPIK_API_KEY=...
# For self-hosted Opik:
# OPIK_URL=https://your-opik-instance.com

# Google Calendar (required for calendar agent)
# Obtain tokens via: python scripts/setup_calendar_oauth.py
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...
# Optional: set if you have a fresh access token
# GOOGLE_ACCESS_TOKEN=...
# Calendar to read (default: primary)
GOOGLE_CALENDAR_ID=primary
# Timezone for "today" (e.g. America/Bogota)
GOOGLE_TIMEZONE=UTC

# Deployment
# For local development use polling (default)
BOT_MODE=polling
# For production with HTTPS use webhook
# BOT_MODE=webhook
# WEBHOOK_URL=https://your-app.railway.app/webhook
PORT=8080

# LLM (optional overrides)
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
